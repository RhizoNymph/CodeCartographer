{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-v2-schema/refs/heads/main/tauri.schema.json",
  "productName": "CodeCartographer",
  "identifier": "dev.codecartographer.app",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../packages/app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter app dev",
    "beforeBuildCommand": "pnpm --filter app build"
  },
  "app": {
    "windows": [
      {
        "title": "CodeCartographer",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
